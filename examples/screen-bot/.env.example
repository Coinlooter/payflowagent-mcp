# PayFlowAgent Screen Bot — Konfiguration
# Kopiere diese Datei nach .env und trage deine Werte ein (oder setze sie als Env-Vars).

# Pflicht: dedizierte Zahler-Wallet (0x + 64 Hex). NICHT deine Haupt-Wallet.
# Braucht etwas USDC + ETH (Gas) auf Base Mainnet.
X402_BUYER_PRIVATE_KEY=0x

# Dienst-Basis-URL
API_BASE=https://payflowagent.net

# Poll-Intervall in ms (Default 5 Min, Minimum 60000)
INTERVAL_MS=300000

# Nur Token mit Score >= MIN_SCORE melden (0..100)
MIN_SCORE=70

# Anzahl Token pro Abruf (1..25)
LIMIT=10

# Zahlungs-RPC (optional)
X402_BUYER_RPC=https://mainnet.base.org

# Optional: Discord-/Slack-kompatibler Webhook fuer Alerts ({content})
# WEBHOOK_URL=https://discord.com/api/webhooks/...
